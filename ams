#include <iostream>
#include <vector>
#include <string>
#include <fstream>
#include <algorithm>

using namespace std;

class Student {
public:
    int id;
    string name;
    float gpa;

    Student(int i, string n, float g) : id(i), name(n), gpa(g) {}

    void display() const {
        cout << "ID: " << id << " | Name: " << name << " | GPA: " << gpa << endl;
    }
};

class ManagementSystem {
private:
    vector<Student> students;
    const string filename = "students.txt";

    void saveToFile() {
        ofstream outFile(filename);
        for (const auto& s : students) {
            outFile << s.id << "," << s.name << "," << s.gpa << endl;
        }
        outFile.close();
    }

public:
    ManagementSystem() {
        ifstream inFile(filename);
        int id;
        string name;
        float gpa;
        char comma;
        while (inFile >> id >> comma && getline(inFile.ignore(), name, ',') && inFile >> gpa) {
            students.emplace_back(id, name, gpa);
        }
        inFile.close();
    }

    void addStudent() {
        int id;
        string name;
        float gpa;
        cout << "Enter ID: "; cin >> id;
        cout << "Enter Name: "; cin.ignore(); getline(cin, name);
        cout << "Enter GPA: "; cin >> gpa;
        students.emplace_back(id, name, gpa);
        saveToFile();
    }

    void showAll() const {
        if (students.empty()) {
            cout << "No records found." << endl;
            return;
        }
        for (const auto& s : students) s.display();
    }

    void searchStudent(int id) const {
        auto it = find_if(students.begin(), students.end(), [id](const Student& s) {
            return s.id == id;
        });
        if (it != students.end()) it->display();
        else cout << "Student not found." << endl;
    }

    void deleteStudent(int id) {
        auto it = remove_if(students.begin(), students.end(), [id](const Student& s) {
            return s.id == id;
        });
        if (it != students.end()) {
            students.erase(it, students.end());
            saveToFile();
            cout << "Record deleted." << endl;
        } else {
            cout << "Record not found." << endl;
        }
    }
};

int main() {
    ManagementSystem sms;
    int choice;
    while (true) {
        cout << "\n1. Add Student\n2. Show All\n3. Search\n4. Delete\n5. Exit\nChoice: ";
        cin >> choice;
        if (choice == 5) break;
        switch (choice) {
            case 1: sms.addStudent(); break;
            case 2: sms.showAll(); break;
            case 3: {
                int id;
                cout << "ID: "; cin >> id;
                sms.searchStudent(id);
                break;
            }
            case 4: {
                int id;
                cout << "ID: "; cin >> id;
                sms.deleteStudent(id);
                break;
            }
        }
    }
    return 0;
}

#include <iostream>
#include <vector>
#include <string>
#include <iomanip>

using namespace std;

struct Product {
    int id;
    string name;
    float price;
};

void showMenu(const vector<Product>& products) {
    cout << "\n--- Super Shop Menu ---" << endl;
    cout << left << setw(10) << "ID" << setw(20) << "Product" << "Price" << endl;
    for (const auto& p : products) {
        cout << left << setw(10) << p.id << setw(20) << p.name << "$" << fixed << setprecision(2) << p.price << endl;
    }
}

int main() {
    vector<Product> inventory = {
        {1, "Bread", 2.50},
        {2, "Milk", 1.80},
        {3, "Eggs", 3.20},
        {4, "Butter", 4.50}
    };

    vector<pair<Product, int>> cart;
    int choice, quantity;
    char cont;

    do {
        showMenu(inventory);
        cout << "\nEnter Product ID to buy: ";
        cin >> choice;

        bool found = false;
        for (const auto& p : inventory) {
            if (p.id == choice) {
                cout << "Enter quantity: ";
                cin >> quantity;
                cart.push_back({p, quantity});
                found = true;
                break;
            }
        }

        if (!found) cout << "Invalid ID!" << endl;

        cout << "Add more items? (y/n): ";
        cin >> cont;
    } while (cont == 'y' || cont == 'Y');

    float total = 0;
    cout << "\n--- Final Receipt ---" << endl;
    cout << left << setw(20) << "Item" << setw(10) << "Qty" << "Total" << endl;
    for (const auto& item : cart) {
        float subtotal = item.first.price * item.second;
        cout << left << setw(20) << item.first.name << setw(10) << item.second << "$" << subtotal << endl;
        total += subtotal;
    }
    cout << "----------------------" << endl;
    cout << "Total Amount: $" << total << endl;

    return 0;
}

