#include <stdio.h>

int main() {
    char op;
    double a, b;
    printf("Enter operator (+, -, *, /): ");
    scanf("%c", &op);
    printf("Enter two operands: ");
    scanf("%lf %lf", &a, &b);

    switch (op) {
        case '+': printf("%.2lf + %.2lf = %.2lf", a, b, a + b); break;
        case '-': printf("%.2lf - %.2lf = %.2lf", a, b, a - b); break;
        case '*': printf("%.2lf * %.2lf = %.2lf", a, b, a * b); break;
        case '/': 
            if (b != 0) printf("%.2lf / %.2lf = %.2lf", a, b, a / b);
            else printf("Error! Division by zero.");
            break;
        default: printf("Error! operator is not correct");
    }
    return 0;
}


